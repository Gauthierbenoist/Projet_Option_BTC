# Copier vers .env à la racine du projet (ne pas committer .env)

# API Deribit
DERIBIT_API_URL=https://www.deribit.com/api/v2
DERIBIT_TIMEOUT=30
DERIBIT_MAX_RETRIES=3

# Règles de nettoyage
CLEAN_MIN_OPEN_INTEREST=0.01
CLEAN_MIN_VOLUME_24H=0
CLEAN_MAX_REL_SPREAD=0.5
CLEAN_IV_MIN=0.01
CLEAN_IV_MAX=5.0
CLEAN_MIN_TTE_DAYS=0

# PostgreSQL — Neon (recommandé pour GitHub Actions)
# Copier la connection string "Direct" depuis le dashboard Neon
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Ou PostgreSQL local / variables séparées
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=deribit_quant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_SSLMODE=prefer

# Exécution planifiée
# - GitHub Actions: horaire défini dans .github/workflows/deribit_daily.yml
# - PIPELINE_SKIP_DB=1 pour n'écrire que le JSON raw (sans Neon)
PIPELINE_SKIP_DB=0
